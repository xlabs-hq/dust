<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href={~p"/images/logo.svg"} />
    <link rel="icon" type="image/png" sizes="64x64" href={~p"/favicon.png"} />
    <.live_title default="Dust Admin">
      {assigns[:page_title]}
    </.live_title>
    <PhoenixVite.Components.assets
      names={["js/admin.js", "css/admin.css"]}
      manifest={{:dust, "priv/static/.vite/manifest.json"}}
      dev_server={PhoenixVite.Components.has_vite_watcher?(DustWeb.Endpoint)}
      to_url={
        if PhoenixVite.Components.has_vite_watcher?(DustWeb.Endpoint),
          do: fn p -> "http://localhost:5288#{p}" end,
          else: &AdminWeb.Endpoint.static_path/1
      }
    />
  </head>
  <body class="bg-gray-50 min-h-screen">
    <nav class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center space-x-8">
            <span class="text-lg font-semibold tracking-tight">Dust Admin</span>
            <div class="flex space-x-1">
              <a
                href="/orgs"
                class="px-3 py-2 rounded text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-700"
              >
                Organizations
              </a>
              <a
                href="/users"
                class="px-3 py-2 rounded text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-700"
              >
                Users
              </a>
              <a
                href="/stores"
                class="px-3 py-2 rounded text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-700"
              >
                Stores
              </a>
              <a
                href="/ops"
                class="px-3 py-2 rounded text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-700"
              >
                Ops
              </a>
            </div>
          </div>
        </div>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
